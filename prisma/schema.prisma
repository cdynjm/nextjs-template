generator client {
  provider = "prisma-client"
   output   = "./generated/prisma"
}

datasource db {
  provider = "mysql"
}

// Example model
model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  created_at DateTime @default(now())

  @@map("users")
}