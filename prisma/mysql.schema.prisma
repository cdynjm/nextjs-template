generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
}
datasource db {
  provider = "mysql"
}

model User {
  id         Int       @id @default(autoincrement())
  name       String?
  email      String    @unique
  password   String
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  @@map("users")
}
